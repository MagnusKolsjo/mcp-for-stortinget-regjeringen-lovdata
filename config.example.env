# =============================================================================
# MCP-server — Stortinget, Lovdata, regjeringen.no
# Konfigurationsmall: kopiera till .env och fyll i dina värden
# .env ska aldrig checkas in i Git
# =============================================================================

# -----------------------------------------------------------------------------
# Stortinget API
# -----------------------------------------------------------------------------

# Bas-URL för Stortingets öppna data-API (ändras inte)
STORTINGET_API_BASE=https://data.stortinget.no/eksport

# Takbegränsning: 100 anrop/minut (respekteras automatiskt av klienten)
# Ändra enbart om Stortinget meddelar annan gräns
STORTINGET_RATE_LIMIT=100

# -----------------------------------------------------------------------------
# Lovdata bulk
# -----------------------------------------------------------------------------

# URL:er för daglig full-snapshot (gratis, ingen nyckel krävs)
# LOVDATA_LOVER_URL=https://api.lovdata.no/v1/publicData/get/gjeldende-lover.tar.bz2
# LOVDATA_FORSKRIFTER_URL=https://api.lovdata.no/v1/publicData/get/gjeldende-sentrale-forskrifter.tar.bz2

# Lokal katalog för tarball-snapshots och diff-kontroll
# LOVDATA_CACHE_DIR=/tmp/lovdata_cache

# -----------------------------------------------------------------------------
# Databas
# -----------------------------------------------------------------------------

# PostgreSQL (krävs för pgvector-sökning):
DATABASE_URL=postgresql://<ANVÄNDARE>:<LÖSENORD>@localhost:5432/<DATABASNAMN>

# SQLite (utan pgvector — semantisk sökning kräver Postgres):
# DATABASE_URL=sqlite:///norge_cache.db

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------

# NbAiLab/nb-sbert-base — norsk sentence-transformer, 768 dim
# Tränad på norsk parlamentarisk och juridisk text (Nasjonalbiblioteket AI-lab)
EMBEDDING_MODEL=NbAiLab/nb-sbert-base

# Batchstorlek vid embedding-generering (standard 32)
# EMBEDDING_BATCH_STORLEK=32

# Max/min teckenlängd per chunk (standard 800/100)
# CHUNK_MAX_TECKEN=800
# CHUNK_MIN_TECKEN=100

# Antal tecken överlapp mellan angränsande chunks (standard 200)
# CHUNK_OVERLAPP=200

# -----------------------------------------------------------------------------
# Query-expansion — termexpansion via LLM
# -----------------------------------------------------------------------------

# Aktivera query-expansion (standard: false — inaktiverat)
QUERY_EXPANSION_ENABLED=false

# OpenAI-kompatibel LLM-endpoint för termexpansion
# Lämna QUERY_EXPANSION_BASE_URL tom för OpenAI-standard
# Exempel Ollama: QUERY_EXPANSION_BASE_URL=http://localhost:11434/v1
# Exempel Anthropic: QUERY_EXPANSION_BASE_URL=https://api.anthropic.com/v1
QUERY_EXPANSION_BASE_URL=
QUERY_EXPANSION_API_KEY=
QUERY_EXPANSION_MODEL=

# Sökväg till promptfil (standard: prompts/expansion_prompt.txt i servermappen)
# QUERY_EXPANSION_PROMPT_FILE=/<SOKVAG_TILL_SERVERMAPP>/prompts/expansion_prompt.txt

# -----------------------------------------------------------------------------
# Daglig schemaläggning — används av --installera-schema i synk_daglig.sh
# -----------------------------------------------------------------------------

# launchd (macOS — kör även om datorn sov vid schemalagd tid)
SCHEMALAGGARE=launchd
CRON_SCHEMA=0 4 * * *
#
# cron (Linux och macOS)
# SCHEMALAGGARE=cron
# CRON_SCHEMA=0 4 * * *
#
# OBS: Lovdata uppdateras dagligen utan fast tidpunkt — 04:00 ger god marginal.
# Ändra CRON_SCHEMA om du vill ha en annan tid (format: "minut timme * * *").

# Explicit sökväg till Python-tolken som launchd/cron ska anropa.
# Lämna tom för att låta skriptet hitta venv-wrappern automatiskt.
# Sätt bara detta om automatiken misslyckas, t.ex. vid ovanlig venv-struktur.
# PYTHON_SOKVÄG=/<SOKVAG_TILL_VENV>/bin/python3

# -----------------------------------------------------------------------------
# MCP-transport
# -----------------------------------------------------------------------------

# Transportläge: stdio (lokal användning) eller http (hostad driftsättning)
MCP_TRANSPORT=stdio

# HTTP-transport: adress och port (används bara när MCP_TRANSPORT=http)
MCP_HOST=127.0.0.1
MCP_PORT=8003

# API-nyckel för Bearer-token-autentisering i HTTP-läget.
# Generera med: python3 -c "import secrets; print(secrets.token_hex(32))"
# Lämna tom för att köra utan autentisering (rekommenderas inte i produktion).
MCP_API_KEY=
